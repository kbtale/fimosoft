---
import { translations } from "../i18n/translations";
import type { Locale } from "../types/game";
import AppEngine from "../components/ui/AppEngine.astro";
import CustomCursor from "../components/ui/CustomCursor.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = translations[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{t.title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <AppEngine />
  </head>
  <body>
    <slot />
    <CustomCursor />
  </body>
</html>

<style is:global>
  /* base styles and scrollbar */
  html,
  body,
  * {
    cursor: none;
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  ::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg-color: #0c0c0c;
    --text-color: #e5e5e5;
    --selection-bg: #7f1d1d;
    --selection-text: #ffffff;
    --accent-red: #7f1d1d;
    --text-accent-red: #dc2626;
  }

  html,
  body {
    height: 100%;
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: "Cinzel Decorative", cursive;
    scrollbar-gutter: stable;
  }

  ::-webkit-scrollbar {
    width: 24px;
    background-color: transparent;
  }

  ::-webkit-scrollbar-track {
    background-color: transparent;
  }

  ::-webkit-scrollbar-thumb {
    background-color: transparent;
    background-image: url("/scroll.svg");
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    border-radius: 0;
  }

  /* Firefox fallback */
  @supports (-moz-appearance: none) {
    * {
      scrollbar-width: thin;
      scrollbar-color: #7f1d1d var(--bg-color);
    }
  }

  /* sliding text component styles */
  .btn-sliding-text {
    overflow: visible;
    display: inline-block;
    vertical-align: middle;
    position: relative;
  }

  .sliding-text-crop {
    height: 1.5rem;
    overflow: hidden;
  }

  .btn-text-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .btn-sliding-text:hover .btn-text-wrapper {
    transform: translateY(-1.5rem);
  }

  .nav-btn,
  .view-toggle-btn,
  .steam-button,
  .social-btn,
  .email-link {
    position: relative;
    overflow: visible;
  }

  .nav-btn::before,
  .view-toggle-btn::before,
  .steam-button::before,
  .social-btn::before,
  .email-link::before {
    content: "";
    position: absolute;
    top: -25px;
    left: -25px;
    right: -25px;
    bottom: -25px;
    z-index: 1;
  }

  .btn-text-primary,
  .btn-text-secondary {
    display: block;
    height: 1.5rem;
    line-height: 1.5rem;
    white-space: nowrap;
  }

  .btn-text-secondary {
    color: var(--text-accent-red);
  }

  /* Lenis CSS */
  html.lenis,
  html.lenis body {
    height: auto;
  }

  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }

  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }

  .lenis.lenis-stopped {
    overflow: hidden;
  }

  .lenis.lenis-scrolling iframe {
    pointer-events: none;
  }

  ::selection {
    background-color: var(--selection-bg);
    color: var(--selection-text);
  }

  body {
    overflow-x: hidden;
  }
</style>
