  }

  #custom-cursor {
    display: none;
    width: 33px;
    height: 33px;
    background-color: var(--accent-red);
    position: fixed;
    top: -16.5px;
    left: -16.5px;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    /* cirlce */
    clip-path: polygon(
      50% 0%,
      65.5% 2.4%,
      79.4% 9.5%,
      90.5% 20.6%,
      97.6% 34.5%,
      100% 50%,
      97.6% 65.5%,
      90.5% 79.4%,
      79.4% 90.5%,
      65.5% 97.6%,
      50% 100%,
      34.5% 97.6%,
      20.6% 90.5%,
      9.5% 79.4%,
      2.4% 65.5%,
      0% 50%,
      2.4% 34.5%,
      9.5% 20.6%,
      20.6% 9.5%,
      34.5% 2.4%
    );
    transition:
      transform 0.15s ease-out,
      background-color 0.3s ease,
      clip-path 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #custom-cursor.cursor-hover {
    background-color: #ffffff;
    /* Morph to triangle */
    clip-path: polygon(
      50% 0%,
      58.3% 16.7%,
      66.7% 33.3%,
      75% 50%,
      83.3% 66.7%,
      91.7% 83.3%,
      100% 100%,
      83.3% 100%,
      66.7% 100%,
      50% 100%,
      33.3% 100%,
      16.7% 100%,
      0% 100%,
      8.3% 83.3%,
      16.7% 66.7%,
      25% 50%,
      33.3% 33.3%,
      41.7% 16.7%,
      50% 0%,
      50% 0%
    );
    transform: scale(1.4);
  }

  #custom-cursor.cursor-active {
    transform: scale(0.85);
  }

  ::selection {
    background-color: var(--selection-bg);
    color: var(--selection-text);
  }

  body {
    overflow-x: hidden;
  }
</style>
