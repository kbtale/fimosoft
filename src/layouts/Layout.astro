<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Fimosoft | Where nightmares take shape</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }
      window.scrollTo(0, 0);
    </script>
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      // Initialize Lenis
      declare global {
        interface Window {
          appLenis: Lenis;
        }
      }
      const lenis = new Lenis();
      window.appLenis = lenis;

      lenis.on("scroll", ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Handle internal links for Lenis
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener("click", function (e) {
          e.preventDefault();
          const href = (e.currentTarget as HTMLAnchorElement).getAttribute(
            "href",
          );
          if (href) {
            const target = document.querySelector(href) as HTMLElement;
            if (target) {
              lenis.scrollTo(target);
            }
          }
        });
      });
    </script>
  </head>
  <body>
    <slot />
    <div id="custom-cursor">
      <!-- SVG content loaded via script -->
    </div>

    <script is:inline>
      if (window.location.pathname === "/" || window.location.pathname === "") {
        const lang = navigator.language.toLowerCase();
        if (lang.startsWith("es")) {
          window.location.replace("/es/");
        }
      }
    </script>
    <script>
      const cursor = document.getElementById("custom-cursor");

      const updateCursor = (e: MouseEvent) => {
        if (!cursor) return;
        cursor.style.display = "block";
        cursor.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0)`;
      };

      window.addEventListener("mousemove", updateCursor);
      window.addEventListener("mousedown", () =>
        cursor?.classList.add("cursor-active"),
      );
      window.addEventListener("mouseup", () =>
        cursor?.classList.remove("cursor-active"),
      );

      // Load cursor SVG dynamically
      let paths: NodeListOf<SVGPathElement> | null = null;
      let isSvgLoaded = false;

      const loadCursorSVG = async () => {
        try {
          const response = await fetch("/images/cross.svg");
          if (!response.ok) throw new Error("Fetch failed");
          const svgText = await response.text();
          if (cursor) {
            cursor.innerHTML = svgText;
            const svg = cursor.querySelector("svg");
            if (svg) {
              svg.setAttribute("width", "100%");
              svg.setAttribute("height", "100%");
              const innerPaths = svg.querySelectorAll("path");
              innerPaths.forEach((p, index) => {
                p.classList.add("cursor-path");
                // Get path length for precise drawing animation
                const length = (p as any).getTotalLength();
                p.style.setProperty("--path-length", length.toString());
                p.style.strokeDasharray = length.toString();
                p.style.strokeDashoffset = length.toString();
                // Start with a 0.1s base delay
                p.style.transitionDelay = `${0.1 + index * 0.05}s`;
              });
              paths = innerPaths as NodeListOf<SVGPathElement>;
              isSvgLoaded = true;
            }
          }
        } catch (e) {
          console.warn("Failed to load cursor SVG", e);
        }
      };

      loadCursorSVG();

      window.addEventListener("mouseover", (e) => {
        const target = (e.target as HTMLElement).closest(
          'a, button, [role="button"], .gallery-img, input[type="submit"], input[type="button"], .logo-block, .media-container',
        );

        if (
          target &&
          isSvgLoaded &&
          !cursor?.classList.contains("cursor-hover")
        ) {
          cursor?.classList.add("cursor-hover");
          const svg = cursor?.querySelector("svg");
          if (svg) svg.style.opacity = "1";
        } else if (!target && cursor?.classList.contains("cursor-hover")) {
          cursor?.classList.remove("cursor-hover");
          const svg = cursor?.querySelector("svg");
          if (svg) svg.style.opacity = "0";
        }
      });

      document.addEventListener("mouseleave", () => {
        if (cursor) cursor.style.display = "none";
      });
    </script>
  </body>
</html>

<style is:global>
  html,
  body,
  * {
    cursor: none;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg-color: #0c0c0c;
    --text-color: #e5e5e5;
    --selection-bg: #7f1d1d;
    --selection-text: #ffffff;
    --accent-red: #7f1d1d;
    --text-accent-red: #dc2626;
  }

  html,
  body {
    height: 100%;
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: "Cinzel Decorative", cursive;
    scrollbar-gutter: stable;
  }

  ::-webkit-scrollbar {
    width: 24px;
    background-color: transparent;
  }

  ::-webkit-scrollbar-track {
    background-color: transparent;
  }

  ::-webkit-scrollbar-thumb {
    background-color: transparent;
    background-image: url("/scroll.svg");
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    border-radius: 0;
  }

  /* Firefox fallback */
  @supports (-moz-appearance: none) {
    * {
      scrollbar-width: thin;
      scrollbar-color: #7f1d1d var(--bg-color);
    }
  }

  /* Sliding Text */
  .btn-sliding-text {
    height: 1.5rem;
    overflow: hidden;
    display: inline-block;
    vertical-align: middle;
  }

  .btn-text-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .btn-sliding-text:hover .btn-text-wrapper {
    transform: translateY(-1.5rem);
  }

  .btn-text-primary,
  .btn-text-secondary {
    display: block;
    height: 1.5rem;
    line-height: 1.5rem;
    white-space: nowrap;
  }

  .btn-text-secondary {
    color: var(--text-accent-red);
  }

  /* Lenis CSS */
  html.lenis,
  html.lenis body {
    height: auto;
  }

  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }

  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }

  .lenis.lenis-stopped {
    overflow: hidden;
  }

  .lenis.lenis-scrolling iframe {
    pointer-events: none;
  }

  #custom-cursor {
    display: none;
    width: 60px;
    height: 60px;
    background-color: var(--accent-red);
    border-radius: 50%;
    position: fixed;
    top: -30px;
    left: -30px;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    transition:
      transform 0.1s ease-out,
      background-color 0.3s ease;
    overflow: hidden;
  }

  .cursor-path {
    vector-effect: non-scaling-stroke;
    fill: transparent;
    stroke: #000000;
    stroke-width: 1px;
    transition:
      stroke-dashoffset 0.6s cubic-bezier(0.19, 1, 0.22, 1),
      fill 0.4s ease 0.3s;
  }

  /* Trigger drawing on hover */
  #custom-cursor.cursor-hover .cursor-path {
    stroke-dashoffset: 0 !important;
    fill: #000000;
  }

  #custom-cursor.cursor-hover {
    background-color: #ffffff;
  }

  #custom-cursor svg {
    position: absolute;
    top: 15%;
    left: 15%;
    width: 70%;
    height: 70%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  #custom-cursor.cursor-active {
    transform: scale(0.85);
  }

  ::selection {
    background-color: var(--selection-bg);
    color: var(--selection-text);
  }

  body {
    overflow-x: hidden;
  }
</style>
