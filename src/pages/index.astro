---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="landing-container">
		

		<div
			class="noise-overlay"
			style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E&quot;);"
		></div>
		
		<main class="main-content">
			<div class="content-wrapper">
				

				<div class="logo-block text-white">
					<div class="word fimo">
						<span class="letter">F</span>
						<span class="letter">I</span>
						<span class="letter">M</span>
						<span class="letter">O</span>
					</div>
					<div class="word soft">
						<span class="letter">S</span>
						<span class="letter">O</span>
						<span class="letter">F</span>
						<span class="letter">T</span>
					</div>
				</div>


				<div class="tagline-block">
					

					<div class="vertical-divider"></div>
					

					<div class="tagline-text">
						<span class="tagline-word">where</span>
						<span class="tagline-word">nightmares</span>
						<span class="tagline-word">take shape</span>
					</div>

				</div>
			</div>
		</main>
	</div>
</Layout>

<style>


	.landing-container {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(1rem, 4vw, 3rem);
		position: relative;
		overflow: hidden;
	}

	.noise-overlay {
		pointer-events: none;
		position: fixed;
		inset: 0;
		z-index: 50;
		height: 100%;
		width: 100%;
		opacity: 0.03;
		mix-blend-mode: overlay;
	}

	.main-content {
		position: relative;
		z-index: 10;
		width: 100%;
		max-width: 90rem; /* 1440px */
		display: flex;
		justify-content: center;
	}

	.content-wrapper {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		width: 100%;
		gap: clamp(1rem, 4vw, 4rem);
	}


	.logo-block {
		display: flex;
		flex-direction: column;
		font-weight: 700;
		color: #ffffff;
		font-size: clamp(4.5rem, 14vw, 17rem);
		line-height: 0.8;
		width: clamp(16rem, 50vw, 65rem);
		filter: drop-shadow(0 25px 25px rgb(0 0 0 / 0.15));
	}

	.word {
		display: flex;
		justify-content: space-between;
		width: 100%;
	}
	
	.soft {
		margin-top: clamp(0.5rem, 2vw, 2rem);
	}

	.letter {
		display: inline-block;

		opacity: 0;
		transform: translateY(50px);
		filter: blur(10px);
	}


	.tagline-block {
		display: flex;
		align-items: flex-end;
		padding-bottom: clamp(0.2rem, 0.8vw, 1.5rem);
		gap: clamp(0.8rem, 2.5vw, 3rem);
	}

	.vertical-divider {
		width: clamp(2px, 0.4vw, 5px);
		background-color: #7f1d1d;
		height: clamp(3.5rem, 11vw, 14rem);
		filter: drop-shadow(0 4px 3px rgb(0 0 0 / 0.07)) drop-shadow(0 2px 2px rgb(0 0 0 / 0.06));

		transform-origin: top;
		transform: scaleY(0);
	}

	.tagline-text {
		display: flex;
		flex-direction: column;
		color: #d1d5db;
		line-height: 1.1;
		letter-spacing: 0.025em;
		font-size: clamp(1.1rem, 3.2vw, 4.5rem);
	}

	.tagline-word {
		display: inline-block;

		opacity: 0;
		transform: translateY(20px);
	}
</style>

<script>
	import { gsap } from "gsap";


	document.addEventListener("DOMContentLoaded", () => {
		

		const tl = gsap.timeline({
			defaults: { ease: "power3.out" }
		});


		tl.to(".fimo .letter", {
			y: 0,
			opacity: 1,
			filter: "blur(0px)",
			duration: 0.8,
			stagger: 0.1,
		})
		

		.to(".soft .letter", {
			y: 0,
			opacity: 1,
			filter: "blur(0px)",
			duration: 0.8,
			stagger: 0.1,
		}, "-=0.6")


		.to(".vertical-divider", {
			scaleY: 1,
			duration: 0.8,
			ease: "expo.inOut"
		}, "-=0.6")


		.to(".tagline-word", {
			y: 0,
			opacity: 1,
			duration: 0.8,
			stagger: 0.1,
		}, "-=0.4");
	});
</script>
