---
import Layout from "../layouts/Layout.astro";
import { translations, type Locale } from "../i18n/translations";
import ScrollReveal from "./ScrollReveal.astro";
interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = translations[locale];
---

<Layout>
  <div class="landing-container">
    <div
      class="noise-overlay"
      style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E&quot;);"
    >
    </div>

    <div class="logo-fixed-layer">
      <div class="logo-fixed-wrapper">
        <div class="logo-block text-white">
          <div class="word fimo">
            <span class="letter">F</span>
            <span class="letter">I</span>
            <span class="letter">M</span>
            <span class="letter">O</span>
          </div>
          <div class="word soft">
            <span class="letter">S</span>
            <span class="letter">O</span>
            <span class="letter">F</span>
            <span class="letter">T</span>
          </div>
        </div>
        <div
          class="tagline-block"
          style="visibility: hidden; pointer-events: none;"
        >
          <div class="vertical-divider"></div>
          <div class="tagline-text">
            {t.tagline.map((word) => <span class="tagline-word">{word}</span>)}
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Section -->
    <main class="hero-section">
      <div class="content-wrapper">
        <div class="logo-ghost">
          <div class="word">FIMO</div>
          <div class="word">SOFT</div>
        </div>

        <div class="tagline-block">
          <div class="vertical-divider"></div>

          <div class="tagline-text">
            {t.tagline.map((word) => <span class="tagline-word">{word}</span>)}
          </div>
        </div>
      </div>
    </main>

    <!-- Scroll Content -->
    <div class="scrolling-content">
      <ScrollReveal
        baseOpacity={0.1}
        enableBlur={true}
        baseRotation={3}
        blurStrength={3}
      >
        We're working in the shadows to bring you something chilling...
        <br />
        The darkness hides secrets yet to be unveiled.
      </ScrollReveal>

      <section class="projects-placeholder">
        <h3 class="projects-title">Upcoming Projects</h3>
        <div class="project-cards">
          <div class="card-skeleton">Project Alpha</div>
          <div class="card-skeleton">Project Beta</div>
          <div class="card-skeleton">Project Gamma</div>
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  .landing-container {
    position: relative;
    overflow-x: hidden;
  }

  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
    width: 100%;
    max-width: 90rem;
    margin: 0 auto;
  }

  .noise-overlay {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 50;
    height: 100%;
    width: 100%;
    opacity: 0.03;
    mix-blend-mode: overlay;
  }

  .logo-fixed-layer {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
  }

  .logo-fixed-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    width: 100%;
    gap: clamp(1rem, 4vw, 4rem);
    max-width: 90rem;
    position: relative;
    user-select: none;
    -webkit-user-select: none;
  }

  .logo-ghost {
    visibility: hidden;
    display: flex;
    flex-direction: column;
    font-size: clamp(4.5rem, 14vw, 17rem);
    line-height: 0.8;
    width: clamp(16rem, 50vw, 65rem);
    user-select: none;
    -webkit-user-select: none;
  }

  .scrolling-content {
    position: relative;
    z-index: 10;
    margin-top: 20vh;
  }

  .main-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 90rem; /* 1440px */
    display: flex;
    justify-content: center;
  }

  .content-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    width: 100%;
    gap: clamp(1rem, 4vw, 4rem);
  }

  .logo-block {
    display: flex;
    flex-direction: column;
    font-weight: 700;
    color: #ffffff;
    font-size: clamp(4.5rem, 14vw, 17rem);
    line-height: 0.8;
    width: clamp(16rem, 50vw, 65rem);
    filter: drop-shadow(0 25px 25px rgb(0 0 0 / 0.15));
    pointer-events: auto;
  }

  .word {
    display: flex;
    justify-content: space-between;
    width: 100%;
  }

  .soft {
    margin-top: clamp(0.5rem, 2vw, 2rem);
  }

  .letter {
    display: inline-block;

    opacity: 0;
    transform: translateY(50px);
    filter: blur(10px);
  }

  .tagline-block {
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(0.2rem, 0.8vw, 1.5rem);
    gap: clamp(0.8rem, 2.5vw, 3rem);
  }

  .vertical-divider {
    width: clamp(2px, 0.4vw, 5px);
    background-color: #7f1d1d;
    height: clamp(3.5rem, 11vw, 14rem);
    filter: drop-shadow(0 4px 3px rgb(0 0 0 / 0.07))
      drop-shadow(0 2px 2px rgb(0 0 0 / 0.06));

    transform-origin: top;
    transform: scaleY(0);
  }

  .tagline-text {
    display: flex;
    flex-direction: column;
    color: #d1d5db;
    line-height: 1.1;
    letter-spacing: 0.025em;
    font-size: clamp(1.1rem, 3.2vw, 4.5rem);
  }

  .tagline-word {
    display: inline-block;

    opacity: 0;
    transform: translateY(20px);
  }

  /* Projects Section Placeholder */
  .projects-placeholder {
    padding: 15vh 5vw;
    max-width: 90rem;
    margin: 0 auto;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .projects-title {
    font-size: clamp(2rem, 5vw, 4rem);
    margin-bottom: 3rem;
    color: #ffffff;
  }

  .project-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .card-skeleton {
    height: 400px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.2);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    position: relative;
    overflow: hidden;
  }

  .card-skeleton::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.02),
      transparent
    );
    transform: translateX(-100%);
    animation: shimmer 3s infinite;
  }

  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const tl = gsap.timeline({
      defaults: { ease: "power3.out" },
    });

    tl.to(".fimo .letter", {
      y: 0,
      opacity: 1,
      filter: "blur(0px)",
      duration: 0.8,
      stagger: 0.1,
    })

      .to(
        ".soft .letter",
        {
          y: 0,
          opacity: 1,
          filter: "blur(0px)",
          duration: 0.8,
          stagger: 0.1,
        },
        "-=0.6",
      )

      .to(
        ".vertical-divider",
        {
          scaleY: 1,
          duration: 0.8,
          ease: "expo.inOut",
        },
        "-=0.6",
      )

      .to(
        ".tagline-word",
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          stagger: 0.1,
        },
        "-=0.4",
      );

    const allLetters = document.querySelectorAll(
      ".letter",
    ) as NodeListOf<HTMLElement>;
    const spacing = 35;

    if (allLetters.length > 0) {
      // Pin hero section during transition
      const scrollTl = gsap.timeline({
        scrollTrigger: {
          trigger: ".hero-section",
          start: "top top",
          end: "+=100%",
          scrub: 0.5,
          pin: true,
          pinSpacing: false, // Allow content to scroll up immediately
        },
      });

      // Capture element positions after entrance animation
      tl.then(() => {
        let cumulativeY = 32;

        allLetters.forEach((letter, index) => {
          const rect = letter.getBoundingClientRect();

          // Destination: X-center=32, Y-center=cumulativeY
          const targetX = 32 - (rect.left + rect.width / 2);
          const targetY = cumulativeY - (rect.top + rect.height / 2);

          scrollTl.to(
            letter,
            {
              x: targetX,
              ease: "power1.out",
            },
            0,
          );

          scrollTl.to(
            letter,
            {
              y: targetY,
              ease: "power1.in",
            },
            0,
          );

          // Rotation and scaling
          scrollTl.to(
            letter,
            {
              rotation: 90,
              scale: 0.2,
              transformOrigin: "center center",
              ease: "none",
            },
            0,
          );

          const currentText = letter.textContent?.trim();
          const nextLetter = allLetters[index + 1];
          const nextText = nextLetter?.textContent?.trim();

          let gap = spacing;
          if (nextText === "I" || currentText === "I") {
            gap = spacing * 0.75;
          }
          cumulativeY += gap;
        });

        // Fade out tagline
        scrollTl.to(
          ".tagline-block",
          {
            opacity: 0,
            x: 50,
            ease: "power2.inOut",
          },
          0,
        );
      });
    }
  });
</script>
