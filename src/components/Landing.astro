---
import Layout from "../layouts/Layout.astro";
import { translations } from "../i18n/translations";
import type { Locale } from "../types/game";
import ScrollReveal from "./ScrollReveal.astro";
import GameCard from "./GameCard.astro";
import Navbar from "./Navbar.astro";
import Contact from "./Contact.astro";
interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = translations[locale];
---

<Layout locale={locale}>
  <Navbar locale={locale} />
  <div class="landing-container">
    <!-- background video -->
    <div class="video-background">
      <video
        id="bg-video"
        autoplay
        muted
        loop
        playsinline
        class="bg-video-hidden"
      >
        <source src={t.heroVideo} type="video/mp4" />
      </video>
      <canvas id="dither-canvas"></canvas>
    </div>

    <div class="logo-fixed-layer">
      <div class="logo-fixed-wrapper">
        <div class="logo-block text-white">
          <div class="word fimo">
            <span class="letter">F</span>
            <span class="letter">I</span>
            <span class="letter">M</span>
            <span class="letter">O</span>
          </div>
          <div class="word soft">
            <span class="letter">S</span>
            <span class="letter">O</span>
            <span class="letter">F</span>
            <span class="letter">T</span>
          </div>
        </div>
        <div
          class="tagline-block"
          style="visibility: hidden; pointer-events: none;"
        >
          <div class="vertical-divider"></div>
          <div class="tagline-text">
            {t.tagline.map((word) => <span class="tagline-word">{word}</span>)}
          </div>
        </div>
      </div>
    </div>

    <!-- Hero Section -->
    <main class="hero-section">
      <div class="content-wrapper">
        <div class="logo-ghost">
          <div class="word">FIMO</div>
          <div class="word">SOFT</div>
        </div>

        <div class="tagline-block">
          <div class="vertical-divider"></div>

          <div class="tagline-text">
            {t.tagline.map((word) => <span class="tagline-word">{word}</span>)}
          </div>
        </div>
      </div>
    </main>

    <!-- Scroll Content -->
    <!-- intro text -->
    <div class="scrolling-content">
      <ScrollReveal
        baseOpacity={0.1}
        enableBlur={true}
        baseRotation={3}
        blurStrength={3}
      >
        {t.heroIntro[0]}
        <br />
        {t.heroIntro[1]}
      </ScrollReveal>

      <!-- games section -->
      <section class="projects-placeholder">
        <h3 class="projects-title section-title-games">{t.gamesTitle}</h3>
        <div class="project-cards-grid">
          {t.games.map((game) => <GameCard game={game} locale={locale} />)}
        </div>
      </section>

      <Contact locale={locale} />
    </div>
  </div>
</Layout>

<style>
  /* Global Styles */
  .landing-container {
    position: relative;
    overflow-x: hidden;
  }

  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
    width: 100%;
    max-width: 90rem;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .video-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  #dither-canvas {
    width: 100%;
    height: 100%;
  }

  .bg-video-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .logo-fixed-layer {
    position: fixed;
    inset: 0;
    z-index: 20;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
  }

  .logo-fixed-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    width: 100%;
    gap: clamp(1rem, 4vw, 4rem);
    max-width: 90rem;
    position: relative;
    user-select: none;
    -webkit-user-select: none;
  }

  .logo-ghost {
    visibility: hidden;
    display: flex;
    flex-direction: column;
    font-size: clamp(4.5rem, 14vw, 17rem);
    line-height: 0.8;
    width: clamp(16rem, 50vw, 65rem);
    user-select: none;
    -webkit-user-select: none;
  }

  .scrolling-content {
    position: relative;
    z-index: 10;
    margin-top: 20vh;
  }

  .content-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    width: 100%;
    gap: clamp(1rem, 4vw, 4rem);
    position: relative;
    z-index: 10;
    max-width: 90rem;
  }

  .logo-block {
    display: flex;
    flex-direction: column;
    font-weight: 700;
    color: #ffffff;
    font-size: clamp(4.5rem, 14vw, 17rem);
    line-height: 0.8;
    width: clamp(16rem, 50vw, 65rem);
    pointer-events: auto;
  }

  .logo-block.is-scrolled {
    pointer-events: none;
  }

  .word {
    display: flex;
    justify-content: space-between;
    width: 100%;
  }

  .soft {
    margin-top: clamp(0.5rem, 2vw, 2rem);
  }

  .letter {
    position: relative;
    display: inline-block;
    opacity: 0;
    transform: translateY(50px);
    pointer-events: auto;
    padding: 0.5rem;
    margin: -0.5rem;
  }

  .logo-block.is-sidebar .letter::after {
    content: "";
    position: absolute;
    inset: -0.2em -1.25em;
    z-index: 1;
    pointer-events: auto;
  }

  .tagline-block {
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(0.2rem, 0.8vw, 1.5rem);
    gap: clamp(0.8rem, 2.5vw, 3rem);
    transform: translateY(clamp(0.1rem, 0.5vw, 0.8rem));
  }

  .vertical-divider {
    width: clamp(2px, 0.4vw, 5px);
    background-color: #7f1d1d;
    height: clamp(3.5rem, 11vw, 14rem);
    filter: drop-shadow(0 4px 3px rgb(0 0 0 / 0.07))
      drop-shadow(0 2px 2px rgb(0 0 0 / 0.06));

    transform-origin: top;
    transform: scaleY(0);
  }

  .tagline-text {
    display: flex;
    flex-direction: column;
    color: #d1d5db;
    line-height: 1.1;
    letter-spacing: 0.025em;
    font-size: clamp(1.1rem, 3.2vw, 4.5rem);
  }

  .tagline-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
  }

  /* Projects Section Placeholder */
  .projects-placeholder {
    padding: 15vh 5vw;
    max-width: 90rem;
    margin: 0 auto;
  }

  .projects-title {
    font-size: clamp(2rem, 5vw, 4rem);
    margin-bottom: 3rem;
    color: #ffffff;
    /* Pre-animation state */
    opacity: 0;
    transform: translateY(60px);
    filter: blur(15px);
  }

  .project-cards-grid {
    display: flex;
    flex-direction: column;
    gap: 8rem;
    width: 100%;
  }
</style>

<script>
  // main page animations
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import type Lenis from "lenis";

  gsap.registerPlugin(ScrollTrigger);

  type AppWindow = Window & typeof globalThis & { appLenis?: Lenis };

  let resizeTimer: number | undefined;
  let heroScrollTimeline: gsap.core.Timeline | null = null;

  const restoreScroll = () => {
    document.body.style.overflow = "";
    const win = window as AppWindow;
    if (win.appLenis) win.appLenis.start();
  };

  const clearHeroScrollTimeline = () => {
    if (!heroScrollTimeline) return;
    heroScrollTimeline.scrollTrigger?.kill();
    heroScrollTimeline.kill();
    heroScrollTimeline = null;

    document.querySelectorAll(".letter").forEach((el) => {
      gsap.set(el, {
        x: 0,
        y: 0,
        rotation: 0,
        scale: 1,
        opacity: 1,
        filter: "blur(0px)",
        transformOrigin: "50% 50%",
      });
    });
    gsap.set(".tagline-block", { opacity: 1, x: 0, filter: "blur(0px)" });
  };

  const buildHeroScrollTimeline = () => {
    clearHeroScrollTimeline();

    const allLetters = document.querySelectorAll(
      ".letter",
    ) as NodeListOf<HTMLElement>;
    if (allLetters.length === 0) return;

    const rects = Array.from(allLetters).map((l) => l.getBoundingClientRect());

    const t = Math.max(0, Math.min(1, (window.innerHeight - 400) / 500));
    const spacing = 16 + t * 19;

    const scrollTl = gsap.timeline({
      scrollTrigger: {
        trigger: ".hero-section",
        start: "top top",
        end: "+=100%",
        scrub: 0.5,
        pin: true,
        pinSpacing: false,
      },
    });

    const isMobile = window.innerWidth < 768;
    const sidebarX = isMobile ? 16 : 32;
    const sidebarScale = isMobile ? 0.12 : 0.2;
    const sidebarSpacing = isMobile ? spacing * 0.6 : spacing;
    let cumulativeY = isMobile ? 16 : 32;

    allLetters.forEach((letter, index) => {
      const rect = rects[index];
      const targetX = sidebarX - (rect.left + rect.width / 2);
      const targetY = cumulativeY - (rect.top + rect.height / 2);

      scrollTl.to(letter, { x: targetX, ease: "power1.out" }, 0);
      scrollTl.to(letter, { y: targetY, ease: "power1.in" }, 0);
      scrollTl.to(
        letter,
        {
          rotation: 90,
          scale: sidebarScale,
          transformOrigin: "center center",
          ease: "none",
        },
        0,
      );

      const currentText = letter.textContent?.trim();
      const nextLetter = allLetters[index + 1];
      const nextText = nextLetter?.textContent?.trim();

      let gap = sidebarSpacing;
      const pair = (currentText || "") + (nextText || "");
      if (pair === "IM") {
        gap = sidebarSpacing * 0.9;
      } else if (pair === "MO") {
        gap = sidebarSpacing * 1.2;
      } else if (nextText === "I" || currentText === "I") {
        gap = sidebarSpacing * 0.75;
      } else if (nextText === "M" || currentText === "M") {
        gap = sidebarSpacing * 1.3;
      }
      cumulativeY += gap;
    });

    scrollTl.to(
      ".tagline-block",
      {
        opacity: 0,
        x: 50,
        filter: "blur(10px)",
        ease: "power2.inOut",
      },
      0,
    );

    heroScrollTimeline = scrollTl;
  };

  function initEntranceAnimation() {
    const win = window as AppWindow;
    document.body.style.overflow = "hidden";
    if (win.appLenis) win.appLenis.stop();

    gsap.set(".letter", { filter: "blur(10px)" });
    gsap.set(".tagline-word", { filter: "blur(5px)" });

    const tl = gsap.timeline({
      defaults: { ease: "power3.out" },
      onComplete: () => {
        restoreScroll();
        buildHeroScrollTimeline();
        ScrollTrigger.refresh();
      },
    });

    tl.to(".fimo .letter", {
      y: 0,
      opacity: 1,
      filter: "blur(0px)",
      duration: 0.6,
      stagger: 0.06,
      clearProps: "filter",
    })
      .to(
        ".soft .letter",
        {
          y: 0,
          opacity: 1,
          filter: "blur(0px)",
          duration: 0.6,
          stagger: 0.06,
          clearProps: "filter",
        },
        "-=0.3",
      )
      .to(
        ".vertical-divider",
        { scaleY: 1, duration: 0.6, ease: "expo.inOut" },
        "-=0.3",
      )
      .to(
        ".tagline-word",
        {
          y: 0,
          opacity: 1,
          filter: "blur(0px)",
          duration: 0.6,
          stagger: 0.06,
          clearProps: "filter",
        },
        "-=0.2",
      );
  }

  function initSectionReveals() {
    gsap.to(".section-title-games", {
      scrollTrigger: {
        trigger: ".section-title-games",
        start: "top 95%",
        toggleActions: "play none none reverse",
      },
      duration: 1.5,
      opacity: 1,
      y: 0,
      filter: "blur(0px)",
      ease: "power4.out",
    });

    const cards = gsap.utils.toArray(".game-card") as HTMLElement[];
    cards.forEach((card, index) => {
      gsap.to(card, {
        scrollTrigger: {
          trigger: card,
          start: "top 92%",
          toggleActions: "play none none reverse",
        },
        duration: 1.8,
        opacity: 1,
        y: 0,
        filter: "blur(0px)",
        ease: "expo.out",
        delay: index % 2 === 0 ? 0 : 0.1,
      });
    });
  }

  const handlers = {
    onScroll: () => {
      const logoBlock = document.querySelector(".logo-block");
      const scrollY = window.scrollY;
      if (scrollY > 50) {
        logoBlock?.classList.add("is-scrolled");
      } else {
        logoBlock?.classList.remove("is-scrolled");
      }

      if (scrollY > 400) {
        logoBlock?.classList.add("is-sidebar");
      } else {
        logoBlock?.classList.remove("is-sidebar");
      }
    },
    onClick: (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      const el = target.closest(".is-sidebar .letter");
      if (el && window.scrollY > 100) {
        const win = window as AppWindow;
        if (win.appLenis) {
          win.appLenis.scrollTo(0, { duration: 2.5 });
        } else {
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      }
    },
    onResize: () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        buildHeroScrollTimeline();
        ScrollTrigger.refresh();
      }, 150);
    },
  };

  function initSidebarBehavior() {
    window.addEventListener("scroll", handlers.onScroll);
    document.addEventListener("click", handlers.onClick);
  }

  function initResizeHandler() {
    window.addEventListener("resize", handlers.onResize);
  }

  const onDOMContentLoaded = () => {
    initEntranceAnimation();
    initSectionReveals();
    initSidebarBehavior();
    initResizeHandler();
  };

  const onWindowLoad = () => {
    ScrollTrigger.refresh();
  };

  document.addEventListener("DOMContentLoaded", onDOMContentLoaded);
  window.addEventListener("load", onWindowLoad);
</script>

<script>
  // background video visual effect
  // Halftone dither renderer for background video
  const video = document.getElementById("bg-video") as HTMLVideoElement;
  const canvas = document.getElementById("dither-canvas") as HTMLCanvasElement;

  if (typeof OffscreenCanvas !== "undefined") {
    const ctx = canvas.getContext("2d", { willReadFrequently: true })!;

    const DOT_SPACING = 8;
    const MAX_DOT_SIZE = 5;
    const TARGET_FPS = 18;
    const FPS_INTERVAL = 1000 / TARGET_FPS;

    let lastFrameTime = 0;
    let cols = 0;
    let rows = 0;
    let sampleCanvas: OffscreenCanvas;
    let sampleCtx: OffscreenCanvasRenderingContext2D;

    const resizeCanvas = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      cols = Math.ceil(canvas.width / DOT_SPACING);
      rows = Math.ceil(canvas.height / DOT_SPACING);
      sampleCanvas = new OffscreenCanvas(cols, rows);
      sampleCtx = sampleCanvas.getContext("2d")!;
    };

    const drawHalftone = (timestamp: number) => {
      requestAnimationFrame(drawHalftone);
      if (timestamp - lastFrameTime < FPS_INTERVAL) return;
      lastFrameTime = timestamp;

      ctx.fillStyle = "rgba(0, 0, 0, 0.6)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      sampleCtx.drawImage(video, 0, 0, cols, rows);
      const pixels = sampleCtx.getImageData(0, 0, cols, rows).data;

      ctx.fillStyle = "#333333";
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          const i = (y * cols + x) * 4;
          const brightness = (pixels[i] + pixels[i + 1] + pixels[i + 2]) / 765;
          const size = brightness * MAX_DOT_SIZE;

          if (size > 0.5) {
            const half = size * 0.5;
            ctx.fillRect(
              x * DOT_SPACING - half,
              y * DOT_SPACING - half,
              size,
              size,
            );
          }
        }
      }
    };

    resizeCanvas();
    const onVideoResize = () => resizeCanvas();
    window.addEventListener("resize", onVideoResize);

    const startDither = () => {
      requestAnimationFrame(drawHalftone);
    };

    if (!video.paused) {
      startDither();
    } else {
      video.addEventListener("playing", startDither, { once: true });
    }
  } else {
    console.warn("Dither background disabled: OffscreenCanvas not supported.");
  }
</script>
