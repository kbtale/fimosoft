---
import type { Game } from "../types/game";

interface Props {
  game: Game;
}

const { game } = Astro.props;
const hasVideo = !!game.videoUrl;
const coverImage = game.screenshots.length > 0 ? game.screenshots[0] : "";
const galleryImages = game.screenshots.slice(1);
---

<article
  class="game-card"
  data-game-id={game.title.replace(/\s+/g, "-").toLowerCase()}
>
  <div class="card-inner">
    <div class="main-content">
      <div class="media-container">
        {
          hasVideo ? (
            <video
              class="hero-media"
              autoplay
              muted
              loop
              playsinline
              poster={coverImage}
            >
              <source src={game.videoUrl} type="video/mp4" />
            </video>
          ) : (
            <img
              class="hero-media"
              src={coverImage}
              alt={game.title}
              loading="lazy"
            />
          )
        }
        <div class="media-overlay">
          <div class="overlay-info">
            <h3 class="title">{game.title}</h3>
            <div class="meta">
              <span class="release-date">{game.releaseDate}</span>
            </div>
            <button class="view-toggle-btn">
              <span class="btn-text">View more</span>
              <svg
                class="btn-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M12 5v14M5 12h14" class="plus-path"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="genres-panel">
        <div class="genres">
          {
            game.genre
              .split(",")
              .map((genre) => <span class="genre-tag">{genre.trim()}</span>)
          }
        </div>
      </div>
    </div>

    <div class="details-panel">
      <div class="details-content">
        <p class="description">{game.description}</p>
        {
          galleryImages.length > 0 && (
            <div class="gallery">
              {galleryImages.map((img) => (
                <img
                  class="gallery-img"
                  src={img}
                  alt={`Screenshot of ${game.title}`}
                  loading="lazy"
                />
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</article>

<script>
  import { gsap } from "gsap";

  function initCard(card: HTMLElement) {
    if (card.dataset.initialized) return;
    card.dataset.initialized = "true";

    const btn = card.querySelector(".view-toggle-btn");
    const btnText = card.querySelector(".btn-text");
    const mediaContainer = card.querySelector(".media-container");
    const detailsPanel = card.querySelector(".details-panel") as HTMLElement;
    const genresPanel = card.querySelector(".genres-panel") as HTMLElement;
    const plusPath = card.querySelector(".plus-path");

    const mainContent = card.querySelector(".main-content");

    let isOpen = false;

    // Responsive check
    const isDesktop = () => window.innerWidth >= 768;

    const tl = gsap.timeline({
      paused: true,
      defaults: { ease: "power3.inOut", duration: 0.8 },
    });

    if (isDesktop()) {
      tl.set([detailsPanel, genresPanel], { display: "block" })
        .to(mainContent, { width: "55%" }, 0)
        .to(mediaContainer, { width: "100%", borderRadius: "12px 0 0 12px" }, 0)
        .to(
          detailsPanel,
          {
            width: "45%",
            height: "auto",
            opacity: 1,
            filter: "blur(0px)",
            pointerEvents: "auto",
          },
          0,
        )
        .to(
          genresPanel,
          { height: "auto", opacity: 1, filter: "blur(0px)", marginTop: "2rem" },
          0.3,
        )
        .to(plusPath, { rotation: 45, transformOrigin: "center center" }, 0);
    } else {
      // Mobile
      tl.set([detailsPanel, genresPanel], { display: "block" }).to(
        detailsPanel,
        {
          height: "auto",
          opacity: 1,
          filter: "blur(0px)",
          marginTop: "2rem",
          pointerEvents: "auto",
        },
        0,
      )
        .to(genresPanel, { height: "auto", opacity: 1, filter: "blur(0px)" }, 0)
        .to(plusPath, { rotation: 45, transformOrigin: "center center" }, 0);
    }

    btn?.addEventListener("click", (e) => {
      e.stopPropagation();
      if (!isOpen) {
        tl.play();
        if (btnText) btnText.textContent = "View less";
      } else {
        tl.reverse();
        if (btnText) btnText.textContent = "View more";
      }
      isOpen = !isOpen;
    });
  }

  // Initialize all cards
  document
    .querySelectorAll(".game-card")
    .forEach((card) => initCard(card as HTMLElement));
</script>

<style>
  .game-card {
    width: 100%;
    position: relative;
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  @media (min-width: 768px) {
    .card-inner {
      flex-direction: row;
      align-items: stretch;
    }
  }

  .main-content {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .media-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
  }

  @media (min-width: 768px) {
    .media-container {
      width: 90%;
      transition: border-radius 0.6s ease;
    }
  }

  .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.01);
  }

  .media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.95) 0%,
      rgba(0, 0, 0, 0.4) 30%,
      rgba(0, 0, 0, 0) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: clamp(1.5rem, 3vw, 3rem);
  }

  .overlay-info {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .title {
    font-size: clamp(1.8rem, 5vw, 3.5rem);
    color: #fff;
    margin: 0;
    font-weight: 700;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .release-date {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
  }

  .view-toggle-btn {
    align-self: flex-start;
    margin-top: 1.5rem;
    background: #fff;
    color: #000;
    border: none;
    padding: 0.9rem 2rem;
    border-radius: 100px;
    font-size: 0.95rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
    transition:
      transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      background 0.2s ease;
  }

  .view-toggle-btn:hover {
    transform: scale(1.05);
    background: #7f1d1d;
    color: #fff;
  }

  .btn-icon {
    width: 20px;
    height: 20px;
  }

  /* Genres Panel */
  .genres-panel {
    width: 100%;
    height: 0;
    opacity: 0;
    display: none;
    overflow: hidden;
    filter: blur(10px);
    will-change: filter;
  }

  @media (min-width: 768px) {
    .genres-panel {
      width: 90%; /* Match media container initial centering */
    }
  }

  @media (max-width: 767px) {
    .genres-panel {
      height: auto;
      opacity: 1;
      margin-top: 1.5rem;
    }
  }

  .genres {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .genre-tag {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #e5e5e5;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.4rem 1rem;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Details Panel */
  .details-panel {
    width: 0;
    height: 0;
    opacity: 0;
    display: none;
    overflow: hidden;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 0 12px 12px 0;
    filter: blur(10px);
    will-change: filter;
  }

  @media (max-width: 767px) {
    .details-panel {
      width: 100%;
      height: 0;
      background: transparent;
    }
  }

  .details-content {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 2rem;
  }

  @media (min-width: 768px) {
    .details-content {
      padding: 3rem;
    }
  }

  .description {
    font-size: 1.2rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 3rem;
  }

  .gallery {
    margin-top: auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .gallery-img:hover {
    transform: scale(1.05);
    border-color: rgba(255, 255, 255, 0.3);
  }
</style>
