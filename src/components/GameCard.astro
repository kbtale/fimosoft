---
import type { Game } from "../types/game";
import SlidingText from "./ui/SlidingText.astro";
import { translations, type Locale } from "../i18n/translations";

interface Props {
  game: Game;
  locale: Locale;
}

const { game, locale } = Astro.props;
const t = translations[locale];
const hasVideo = !!game.videoUrl;
const coverImage = game.screenshots.length > 0 ? game.screenshots[0] : "";
const galleryImages = game.screenshots.slice(1);
---

<article
  class="game-card"
  data-game-id={game.title.replace(/\s+/g, "-").toLowerCase()}
>
  <div class="card-inner">
    <div class="main-content">
      <div class="media-container">
        <div class="media-layers">
          {
            hasVideo ? (
              <>
                <video
                  class="hero-media media-base"
                  autoplay
                  muted
                  loop
                  playsinline
                  poster={coverImage}
                >
                  <source src={game.videoUrl} type="video/mp4" />
                </video>
                <video
                  class="hero-media media-sketch"
                  autoplay
                  muted
                  loop
                  playsinline
                >
                  <source src={game.videoUrl} type="video/mp4" />
                </video>
              </>
            ) : (
              <>
                <img
                  class="hero-media media-base"
                  src={coverImage}
                  alt={game.title}
                  loading="lazy"
                />
                <img
                  class="hero-media media-sketch"
                  src={coverImage}
                  alt={game.title}
                  loading="lazy"
                />
              </>
            )
          }
        </div>
        <div class="media-overlay">
          <div class="overlay-info">
            <h3 class="title">{game.title}</h3>
            <div class="meta">
              <span class="release-date">{game.releaseDate}</span>
            </div>
          </div>
          <button class="view-toggle-btn btn-sliding-text">
            <SlidingText>{t.buttons.details}</SlidingText>
          </button>
        </div>
      </div>

      <div class="genres-panel">
        <h3 class="secondary-title">{game.title}</h3>
        <div class="secondary-meta">
          <span class="secondary-date">{game.releaseDate}</span>
        </div>
      </div>
    </div>

    <div class="details-panel">
      <div class="details-content">
        <div class="genres">
          {
            game.genre
              .split(",")
              .map((genre) => <span class="genre-tag">{genre.trim()}</span>)
          }
        </div>
        <p class="description">{game.description}</p>

        {
          game.steamUrl && (
            <a
              href={game.steamUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="steam-button btn-sliding-text"
            >
              <SlidingText>{t.buttons.steam}</SlidingText>
            </a>
          )
        }

        {
          galleryImages.length > 0 && (
            <div class="gallery">
              {galleryImages.map((img) => (
                <img
                  class="gallery-img"
                  src={img}
                  alt={`Screenshot of ${game.title}`}
                  loading="lazy"
                />
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</article>

<script>
  import { gsap } from "gsap";

  function initCard(card: HTMLElement) {
    if (card.dataset.initialized) return;
    card.dataset.initialized = "true";

    const btn = card.querySelector(".view-toggle-btn");
    const btnText = card.querySelector(".btn-text");
    const mediaContainer = card.querySelector(
      ".media-container",
    ) as HTMLElement;
    const mediaLayers = card.querySelector(".media-layers") as HTMLElement;

    const detailsPanel = card.querySelector(".details-panel") as HTMLElement;
    const genresPanel = card.querySelector(".genres-panel") as HTMLElement;
    const primaryTitle = card.querySelector(".overlay-info");
    const secondaryTitle = card.querySelector(".secondary-title");
    const secondaryMeta = card.querySelector(".secondary-meta");
    const steamBtn = card.querySelector(".steam-button");
    const categories = card.querySelector(".details-content .genres");

    const mainContent = card.querySelector(".main-content");

    let isOpen = false;

    // Responsive check
    const isDesktop = () => window.innerWidth >= 768;

    // Lantern Effect Tracking
    if (mediaContainer && mediaLayers) {
      mediaContainer.addEventListener("mousemove", (e) => {
        const rect = mediaContainer.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        mediaLayers.style.setProperty("--mouse-x", `${x}px`);
        mediaLayers.style.setProperty("--mouse-y", `${y}px`);
      });
    }

    const tl = gsap.timeline({
      paused: true,
      defaults: { ease: "power3.inOut", duration: 0.8 },
    });

    if (isDesktop()) {
      tl.set([detailsPanel, genresPanel], { display: "block" })
        .to(mainContent, { width: "55%" }, 0)
        .to(mediaContainer, { width: "100%", borderRadius: "12px 0 0 12px" }, 0)
        .to(
          detailsPanel,
          {
            width: "45%",
            height: "auto",
            opacity: 1,
            pointerEvents: "auto",
          },
          0,
        )
        .to(primaryTitle, { opacity: 0, y: -20, duration: 0.4 }, 0)
        .to(
          [secondaryTitle, secondaryMeta],
          {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            duration: 0.6,
            stagger: 0.1,
          },
          0.3,
        )
        .to(
          [
            categories,
            card.querySelector(".description"),
            steamBtn,
            ...Array.from(card.querySelectorAll(".gallery-img")),
          ].filter(Boolean),
          {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            stagger: 0.05,
            duration: 0.5,
            ease: "power2.out",
          },
          0.4,
        )
        .to(
          genresPanel,
          {
            height: "auto",
            opacity: 1,
            marginTop: "2rem",
          },
          0.3,
        );
    } else {
      // Mobile
      tl.set([detailsPanel, genresPanel], { display: "block" })
        .to(
          detailsPanel,
          {
            height: "auto",
            opacity: 1,
            marginTop: "2rem",
            pointerEvents: "auto",
          },
          0,
        )
        .to(primaryTitle, { opacity: 0, y: -20, duration: 0.4 }, 0)
        .to(
          [secondaryTitle, secondaryMeta],
          {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            duration: 0.6,
            stagger: 0.1,
          },
          0.2,
        )
        .to(
          [
            categories,
            card.querySelector(".description"),
            steamBtn,
            ...Array.from(card.querySelectorAll(".gallery-img")),
          ].filter(Boolean),
          {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            stagger: 0.05,
            duration: 0.4,
          },
          0.2,
        )
        .to(genresPanel, { height: "auto", opacity: 1 }, 0);
    }

    const toggle = () => {
      if (!isOpen) {
        tl.play();
        btn?.classList.add("btn-active");
      } else {
        tl.reverse();
        btn?.classList.remove("btn-active");
      }
      isOpen = !isOpen;
    };

    btn?.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle();
    });

    mediaContainer?.addEventListener("click", () => {
      toggle();
    });
  }

  // Initialize all cards
  document
    .querySelectorAll(".game-card")
    .forEach((card) => initCard(card as HTMLElement));
</script>

<style>
  .game-card {
    width: 100%;
    position: relative;
    /* Pre-animation state */
    opacity: 0;
    transform: translateY(40px);
    filter: blur(10px);
    will-change: transform, opacity, filter;
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  @media (min-width: 768px) {
    .card-inner {
      flex-direction: row;
      align-items: stretch;
    }
  }

  .main-content {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .media-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    cursor: crosshair;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
  }

  @media (min-width: 768px) {
    .media-container {
      width: 90%;
      transition: border-radius 0.6s ease;
    }
  }

  .media-layers {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hero-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    transition:
      opacity 0.4s ease,
      filter 0.4s ease,
      transform 0.4s ease;
  }

  .media-base {
    z-index: 1;
    filter: saturate(0.7) brightness(0.5);
    transform: scale(1);
  }

  .media-sketch {
    z-index: 2;
    opacity: 0;
    filter: saturate(1.1) brightness(1.2);
    transform: scale(1);

    /* Lantern Effect Mask */
    -webkit-mask-image: radial-gradient(
      circle 150px at var(--mouse-x, 50%) var(--mouse-y, 50%),
      black 20%,
      rgba(0, 0, 0, 0.5) 50%,
      transparent 100%
    );
    mask-image: radial-gradient(
      circle 150px at var(--mouse-x, 50%) var(--mouse-y, 50%),
      black 20%,
      rgba(0, 0, 0, 0.5) 50%,
      transparent 100%
    );
    will-change: mask-image;
  }

  .media-container:hover .media-sketch {
    opacity: 1;
  }

  .dither-trail {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 3;
  }

  .media-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.95) 0%,
      rgba(0, 0, 0, 0.4) 30%,
      rgba(0, 0, 0, 0) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: clamp(1.5rem, 3vw, 3rem);
  }

  .overlay-info {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .title {
    font-size: clamp(1.8rem, 5vw, 3.5rem);
    color: #fff;
    margin: 0;
    font-weight: 700;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .release-date {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
  }

  .view-toggle-btn {
    align-self: flex-start;
    margin-top: 1.5rem;
    background: transparent;
    color: #fff;
    border: none;
    padding: 0;
    font-size: 1.1rem;
    font-family: "Cinzel Decorative", cursive;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
  }

  .view-toggle-btn.btn-active .btn-text-wrapper {
    transform: translateY(-1.5rem);
  }

  .view-toggle-btn.btn-active:hover .btn-text-wrapper {
    transform: translateY(0);
  }

  .secondary-title {
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.5rem;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    will-change: transform, filter, opacity;
  }

  .secondary-meta {
    opacity: 0;
    filter: blur(10px);
    transform: translateY(10px);
    will-change: transform, filter, opacity;
  }

  .secondary-date {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
  }

  /* Genres Panel */
  .genres-panel {
    width: 100%;
    height: 0;
    opacity: 0;
    display: none;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .genres-panel {
      width: 90%;
    }
  }

  @media (max-width: 767px) {
    .genres-panel {
      height: auto;
      opacity: 1;
      margin-top: 1.5rem;
    }
  }

  .genres {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    will-change: transform, filter, opacity;
  }

  .genre-tag {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #e5e5e5;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.4rem 1rem;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Details Panel */
  .details-panel {
    width: 0;
    height: 0;
    opacity: 0;
    display: none;
    overflow: hidden;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 0 12px 12px 0;
  }

  @media (max-width: 767px) {
    .details-panel {
      width: 100%;
      height: 0;
      background: transparent;
    }
  }

  .details-content {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 2rem;
  }

  @media (min-width: 768px) {
    .details-content {
      padding: 2.5rem;
    }
  }

  .description {
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.9);
    margin: 1rem 0 0.5rem 0;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    will-change: transform, filter, opacity;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .steam-button {
    align-self: flex-start;
    background: transparent;
    color: #fff;
    border: none;
    padding: 0;
    font-size: 1.1rem;
    font-family: "Cinzel Decorative", cursive;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    display: inline-flex;
    text-decoration: none;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    will-change: transform, filter, opacity;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .gallery-img:hover {
    transform: scale(1.05);
    border-color: rgba(255, 255, 255, 0.3);
  }
</style>
