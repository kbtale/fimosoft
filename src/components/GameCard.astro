---
import type { Game } from "../types/game";
import SlidingText from "./ui/SlidingText.astro";

interface Props {
  game: Game;
}

const { game } = Astro.props;
const hasVideo = !!game.videoUrl;
const coverImage = game.screenshots.length > 0 ? game.screenshots[0] : "";
const galleryImages = game.screenshots.slice(1);
---

<article
  class="game-card"
  data-game-id={game.title.replace(/\s+/g, "-").toLowerCase()}
>
  <div class="card-inner">
    <div class="main-content">
      <div class="media-container">
        {
          hasVideo ? (
            <video
              class="hero-media"
              autoplay
              muted
              loop
              playsinline
              poster={coverImage}
            >
              <source src={game.videoUrl} type="video/mp4" />
            </video>
          ) : (
            <img
              class="hero-media"
              src={coverImage}
              alt={game.title}
              loading="lazy"
            />
          )
        }
        <canvas class="dither-trail"></canvas>
        <div class="media-overlay">
          <div class="overlay-info">
            <h3 class="title">{game.title}</h3>
            <div class="meta">
              <span class="release-date">{game.releaseDate}</span>
            </div>
          </div>
          <button class="view-toggle-btn btn-sliding-text">
            <SlidingText>Details</SlidingText>
          </button>
        </div>
      </div>

      <div class="genres-panel">
        <h3 class="secondary-title">{game.title}</h3>
        <div class="secondary-meta">
          <span class="secondary-date">{game.releaseDate}</span>
        </div>
      </div>
    </div>

    <div class="details-panel">
      <div class="details-content">
        <div class="genres">
          {
            game.genre
              .split(",")
              .map((genre) => <span class="genre-tag">{genre.trim()}</span>)
          }
        </div>
        <p class="description">{game.description}</p>

        {
          game.steamUrl && (
            <a
              href={game.steamUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="steam-button btn-sliding-text"
            >
              <SlidingText>View on Steam</SlidingText>
            </a>
          )
        }

        {
          galleryImages.length > 0 && (
            <div class="gallery">
              {galleryImages.map((img) => (
                <img
                  class="gallery-img"
                  src={img}
                  alt={`Screenshot of ${game.title}`}
                  loading="lazy"
                />
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</article>

<script>
  import { gsap } from "gsap";

  // --- Dither trail effect ---
  const DOT_SPACING = 5;
  const MAX_DOT = 7;
  const TRAIL_RADIUS = 80;
  const FADE_SPEED = 0.06;

  function initDitherTrail(container: HTMLElement) {
    const canvas = container.querySelector(
      ".dither-trail",
    ) as HTMLCanvasElement;
    const media = container.querySelector(".hero-media") as
      | HTMLVideoElement
      | HTMLImageElement;
    if (!canvas || !media) return;

    const ctx = canvas.getContext("2d", { willReadFrequently: true })!;
    let mouseX = -1;
    let mouseY = -1;
    let isHovering = false;
    let rafId = 0;

    // Offscreen canvas for sampling
    const sampleSize = 32;
    const sampler = new OffscreenCanvas(sampleSize, sampleSize);
    const samplerCtx = sampler.getContext("2d", { willReadFrequently: true })!;

    function resize() {
      const rect = container.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
    }

    function draw() {
      if (!isHovering) {
        // Fade out remaining trail
        ctx.globalCompositeOperation = "destination-out";
        ctx.fillStyle = `rgba(0, 0, 0, ${FADE_SPEED * 3})`;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.globalCompositeOperation = "source-over";

        // Check if canvas is essentially empty
        const pixel = ctx.getImageData(0, 0, 1, 1).data;
        if (pixel[3] < 2) {
          cancelAnimationFrame(rafId);
          rafId = 0;
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          return;
        }
        rafId = requestAnimationFrame(draw);
        return;
      }

      // Fade previous frame
      ctx.globalCompositeOperation = "destination-out";
      ctx.fillStyle = `rgba(0, 0, 0, ${FADE_SPEED})`;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.globalCompositeOperation = "source-over";

      // Sample pixels from media around cursor
      const sx = (mouseX / canvas.width) * sampleSize;
      const sy = (mouseY / canvas.height) * sampleSize;
      try {
        samplerCtx.drawImage(media, 0, 0, sampleSize, sampleSize);
      } catch {
        /* cors or not ready */
      }

      const sampleData = samplerCtx.getImageData(
        Math.max(0, Math.floor(sx) - 2),
        Math.max(0, Math.floor(sy) - 2),
        5,
        5,
      ).data;

      // random dots inside a circle around the cursor
      const NUM_DOTS = 120;
      for (let i = 0; i < NUM_DOTS; i++) {
        const angle = Math.random() * Math.PI * 2;
        const r2 = Math.random();
        const dist = r2 * TRAIL_RADIUS;
        const x = mouseX + Math.cos(angle) * dist;
        const y = mouseY + Math.sin(angle) * dist;

        if (x < 0 || x > canvas.width || y < 0 || y > canvas.height) continue;

        const si =
          (Math.floor((y / canvas.height) * 5) * 5 +
            Math.floor((x / canvas.width) * 5)) *
          4;
        const r = sampleData[si] || 0;
        const g = sampleData[si + 1] || 0;
        const b = sampleData[si + 2] || 0;
        const brightness = (r + g + b) / 765;

        const falloff = 1 - r2;
        const size = brightness * MAX_DOT * falloff;

        if (size > 0.5) {
          ctx.beginPath();
          ctx.arc(x, y, size / 2, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${Math.min(255, r + 40)}, ${Math.min(255, g + 40)}, ${Math.min(255, b + 40)}, ${falloff})`;
          ctx.fill();
        }
      }

      rafId = requestAnimationFrame(draw);
    }

    container.addEventListener("mouseenter", () => {
      resize();
      isHovering = true;
      if (!rafId) rafId = requestAnimationFrame(draw);
    });

    container.addEventListener("mousemove", (e) => {
      const rect = container.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });

    container.addEventListener("mouseleave", () => {
      isHovering = false;
    });

    window.addEventListener("resize", resize);
  }

  function initCard(card: HTMLElement) {
    if (card.dataset.initialized) return;
    card.dataset.initialized = "true";

    const btn = card.querySelector(".view-toggle-btn");
    const btnText = card.querySelector(".btn-text");
    const mediaContainer = card.querySelector(
      ".media-container",
    ) as HTMLElement;
    const detailsPanel = card.querySelector(".details-panel") as HTMLElement;
    const genresPanel = card.querySelector(".genres-panel") as HTMLElement;
    const primaryTitle = card.querySelector(".overlay-info");
    const secondaryTitle = card.querySelector(".secondary-title");
    const secondaryMeta = card.querySelector(".secondary-meta");
    const steamBtn = card.querySelector(".steam-button");
    const categories = card.querySelector(".details-content .genres");

    const mainContent = card.querySelector(".main-content");

    let isOpen = false;

    // Responsive check
    const isDesktop = () => window.innerWidth >= 768;

    // Initialize dither trail
    if (mediaContainer) initDitherTrail(mediaContainer);

    const tl = gsap.timeline({
      paused: true,
      defaults: { ease: "power3.inOut", duration: 0.8 },
    });

    if (isDesktop()) {
      tl.set([detailsPanel, genresPanel], { display: "block" })
        .to(mainContent, { width: "55%" }, 0)
        .to(mediaContainer, { width: "100%", borderRadius: "12px 0 0 12px" }, 0)
        .to(
          detailsPanel,
          {
            width: "45%",
            height: "auto",
            opacity: 1,
            pointerEvents: "auto",
          },
          0,
        )
        .to(primaryTitle, { opacity: 0, y: -20, duration: 0.4 }, 0)
        .to(
          [secondaryTitle, secondaryMeta],
          {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            duration: 0.6,
            stagger: 0.1,
          },
          0.3,
        )
        .to(
          [
            categories,
            card.querySelector(".description"),
            steamBtn,
            ...Array.from(card.querySelectorAll(".gallery-img")),
          ].filter(Boolean),
          {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            stagger: 0.05,
            duration: 0.5,
            ease: "power2.out",
          },
          0.4,
        )
        .to(
          genresPanel,
          {
            height: "auto",
            opacity: 1,
            marginTop: "2rem",
          },
          0.3,
        );
    } else {
      // Mobile
      tl.set([detailsPanel, genresPanel], { display: "block" })
        .to(
          detailsPanel,
          {
            height: "auto",
            opacity: 1,
            marginTop: "2rem",
            pointerEvents: "auto",
          },
          0,
        )
        .to(primaryTitle, { opacity: 0, y: -20, duration: 0.4 }, 0)
        .to(
          [secondaryTitle, secondaryMeta],
          {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            duration: 0.6,
            stagger: 0.1,
          },
          0.2,
        )
        .to(
          [
            categories,
            card.querySelector(".description"),
            steamBtn,
            ...Array.from(card.querySelectorAll(".gallery-img")),
          ].filter(Boolean),
          {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            stagger: 0.05,
            duration: 0.4,
          },
          0.2,
        )
        .to(genresPanel, { height: "auto", opacity: 1 }, 0);
    }

    const toggle = () => {
      if (!isOpen) {
        tl.play();
        btn?.classList.add("btn-active");
      } else {
        tl.reverse();
        btn?.classList.remove("btn-active");
      }
      isOpen = !isOpen;
    };

    btn?.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle();
    });

    mediaContainer?.addEventListener("click", () => {
      toggle();
    });
  }

  // Initialize all cards
  document
    .querySelectorAll(".game-card")
    .forEach((card) => initCard(card as HTMLElement));
</script>

<style>
  .game-card {
    width: 100%;
    position: relative;
    /* Pre-animation state */
    opacity: 0;
    transform: translateY(40px);
    filter: blur(10px);
    will-change: transform, opacity, filter;
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  @media (min-width: 768px) {
    .card-inner {
      flex-direction: row;
      align-items: stretch;
    }
  }

  .main-content {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .media-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    cursor: crosshair;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
  }

  @media (min-width: 768px) {
    .media-container {
      width: 90%;
      transition: border-radius 0.6s ease;
    }
  }

  .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.01);
    pointer-events: none;
  }

  .dither-trail {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 3;
  }

  .media-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.95) 0%,
      rgba(0, 0, 0, 0.4) 30%,
      rgba(0, 0, 0, 0) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: clamp(1.5rem, 3vw, 3rem);
  }

  .overlay-info {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .title {
    font-size: clamp(1.8rem, 5vw, 3.5rem);
    color: #fff;
    margin: 0;
    font-weight: 700;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .release-date {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
  }

  .view-toggle-btn {
    align-self: flex-start;
    margin-top: 1.5rem;
    background: transparent;
    color: #fff;
    border: none;
    padding: 0;
    font-size: 1.1rem;
    font-family: "Cinzel Decorative", cursive;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
  }

  .view-toggle-btn.btn-active .btn-text-wrapper {
    transform: translateY(-1.5rem);
  }

  .view-toggle-btn.btn-active:hover .btn-text-wrapper {
    transform: translateY(0);
  }

  .secondary-title {
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.5rem;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    will-change: transform, filter, opacity;
  }

  .secondary-meta {
    opacity: 0;
    filter: blur(10px);
    transform: translateY(10px);
    will-change: transform, filter, opacity;
  }

  .secondary-date {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
  }

  /* Genres Panel */
  .genres-panel {
    width: 100%;
    height: 0;
    opacity: 0;
    display: none;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .genres-panel {
      width: 90%;
    }
  }

  @media (max-width: 767px) {
    .genres-panel {
      height: auto;
      opacity: 1;
      margin-top: 1.5rem;
    }
  }

  .genres {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    will-change: transform, filter, opacity;
  }

  .genre-tag {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #e5e5e5;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.4rem 1rem;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Details Panel */
  .details-panel {
    width: 0;
    height: 0;
    opacity: 0;
    display: none;
    overflow: hidden;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 0 12px 12px 0;
  }

  @media (max-width: 767px) {
    .details-panel {
      width: 100%;
      height: 0;
      background: transparent;
    }
  }

  .details-content {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 2rem;
  }

  @media (min-width: 768px) {
    .details-content {
      padding: 2.5rem;
    }
  }

  .description {
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.9);
    margin: 1rem 0 0.5rem 0;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    will-change: transform, filter, opacity;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .steam-button {
    align-self: flex-start;
    background: transparent;
    color: #fff;
    border: none;
    padding: 0;
    font-size: 1.1rem;
    font-family: "Cinzel Decorative", cursive;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    display: inline-flex;
    text-decoration: none;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    opacity: 0;
    filter: blur(10px);
    transform: translateY(20px);
    will-change: transform, filter, opacity;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .gallery-img:hover {
    transform: scale(1.05);
    border-color: rgba(255, 255, 255, 0.3);
  }
</style>
